#!/bin/sh

MODE="gui"

# Parse flags
case "$1" in
  --cli) MODE="cli"; shift ;;
  --gui) MODE="gui"; shift ;;
esac

USERNAME="$1"
shift
CMD="$@"

if [ -z "$USERNAME" ] || [ -z "$CMD" ]; then
    echo "Usage: $0 [--cli|--gui] <username> <command...>"
    exit 1
fi

case "$MODE" in
  gui)
    password=$(zenity --password --title="Run        $CMD        as $USERNAME:") || exit 1
    expect 2>/dev/null <<EOF
      spawn runas-cli "$USERNAME" "$CMD"
      expect "Password:"
      send "$password\r"
      expect eof
EOF
    ;;

  cli)
    PS4='\n' set -x
    runas-cli "$USERNAME" "$CMD"
    ;;
esac